# ============================================================
# SIGMA Marketing — Variáveis de Ambiente
# Copie para .env e preencha
# ============================================================

# --- Banco (Neon PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Admin (Multi-tenant) ---
ADMIN_EMAIL="seu@email.com"
ADMIN_NAME="Seu Nome"

# --- URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:3002"
NEXT_PUBLIC_BASE_URL="http://localhost:3002"
PORT=3002

# --- Segurança ---
SESSION_SECRET="trocar-por-string-aleatoria-em-producao"
INTERNAL_API_TOKEN="trocar-por-token-seguro-para-crons"

# --- IA: Chaves de API ---
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# --- IA: Modelos por nível ---
AI_MODEL_WEAK="gpt-4o-mini"
AI_MODEL_MEDIUM="gpt-4o"
AI_MODEL_STRONG="claude-opus-4-20250514"
AI_MODEL_SEARCH="gpt-4o-mini"

# --- Perplexity (busca alternativa — opcional) ---
PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL="sonar-pro"
AI_SEARCH_PROVIDER="openai"

# --- WhatsApp (Z-API) ---
ZAPI_INSTANCE="SUA_INSTANCIA"
ZAPI_TOKEN="SEU_TOKEN"
ZAPI_CLIENT_TOKEN="SEU_CLIENT_TOKEN"

# --- Instagram / Meta (desativado — reativar quando social media voltar) ---
# META_APP_ID="SEU_APP_ID"
# META_APP_SECRET="SEU_APP_SECRET"
# META_REDIRECT_URI="https://app.exemplo.com/api/instagram/callback"
# INSTAGRAM_APP_ID="SEU_APP_ID"
# INSTAGRAM_APP_SECRET="SEU_APP_SECRET"

# --- Apify (Google Maps Scraper para Comercial) ---
APIFY_TOKEN="apify_api_xxxxxxx"
APIFY_GOOGLE_MAPS_ACTOR="compass~crawler-google-places"

# --- Comercial — limites de IA ---
COMERCIAL_RATE_LIMIT_ANALYSIS_PER_DAY=20
COMERCIAL_RATE_LIMIT_PROPOSAL_AI_PER_DAY=30

# --- Comercial — limites de WhatsApp (Sprint 3) ---
COMERCIAL_RATE_LIMIT_WHATSAPP_PER_DAY=100
COMERCIAL_RATE_LIMIT_BULK_WHATSAPP=50
COMERCIAL_BULK_WHATSAPP_DELAY_MS=3000

# ── Gerador de Imagem ──
# Chave mestra para criptografar API keys de provedores no banco.
# Gere com: openssl rand -base64 32
IMAGE_ENCRYPTION_KEY=""

# Vertex AI (Imagen 4) — fallback se não configurado por tenant
GOOGLE_VERTEX_PROJECT_ID=""
GOOGLE_VERTEX_LOCATION="us-central1"

# Fal.ai (Flux 1.1 Pro) — fallback se não configurado por tenant
FAL_KEY=""

# Gemini (Nano Banana) — fallback se não configurado por tenant
GEMINI_API_KEY=""

# Worker — desligue em ambientes de build/CI
IMAGE_WORKER_ENABLED="true"

# Limites de upload (bytes)
IMAGE_MAX_REFERENCE_BYTES="10485760"     # 10 MB por imagem de referência
IMAGE_MAX_BRANDBOOK_BYTES="26214400"     # 25 MB para PDF/HTML do brandbook
