# ============================================================
# Instagram Dashboard - Variaveis de Ambiente
# Copie para .env e preencha
# ============================================================

# --- Neon PostgreSQL ---
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Admin (Multi-tenant) ---
ADMIN_EMAIL="seu@email.com"
ADMIN_NAME="Seu Nome"

# --- URL da Aplicacao ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Meta / Instagram API ---
INSTAGRAM_APP_ID="SEU_APP_ID"
INSTAGRAM_APP_SECRET="SEU_APP_SECRET"

# --- Tunnel (para midias locais) ---
# TUNNEL_URL="https://sua-url.ngrok.io"

PORT=3000

# --- Módulo de Agentes IA (CopyCreator) ---

# Chaves de API
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# Modelos por nível
AI_MODEL_WEAK="gpt-4o-mini"
AI_MODEL_MEDIUM="gpt-4o"
AI_MODEL_STRONG="claude-opus-4-20250514"
AI_MODEL_SEARCH="gpt-4o-mini"

# --- Perplexity (busca alternativa) ---
PERPLEXITY_API_KEY=""
# Deixar vazio se nao usar. Obter em https://www.perplexity.ai/settings/api
PERPLEXITY_MODEL="sonar-pro"
# sonar-pro = pesquisa web + raciocinio | sonar = mais rapido/barato
AI_SEARCH_PROVIDER="openai"
# Trocar para 'perplexity' quando quiser usar Perplexity como provedor de busca

# --- Formulário Público ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# URL base da aplicação (trocar por domínio em produção)
# Exemplo produção: https://app.sigmamarketing.com.br

# --- Z-API (WhatsApp) ---
ZAPI_INSTANCE="SUA_INSTANCIA"
# ID da instância Z-API (ex: 3D5B2AB3A...)
ZAPI_TOKEN="SEU_TOKEN"
# Token da instância Z-API
ZAPI_CLIENT_TOKEN="SEU_CLIENT_TOKEN"
# Token de segurança da conta (header Client-Token)
# Todos os três são obrigatórios para qualquer envio via Z-API
