# ============================================================
# SIGMA Marketing — Variáveis de Ambiente
# Copie para .env e preencha
# ============================================================

# --- Banco (Neon PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Admin (Multi-tenant) ---
ADMIN_EMAIL="seu@email.com"
ADMIN_NAME="Seu Nome"

# --- URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_BASE_URL="http://localhost:3001"
PORT=3001

# --- Segurança ---
SESSION_SECRET="trocar-por-string-aleatoria-em-producao"
INTERNAL_API_TOKEN="trocar-por-token-seguro-para-crons"

# --- IA: Chaves de API ---
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# --- IA: Modelos por nível ---
AI_MODEL_WEAK="gpt-4o-mini"
AI_MODEL_MEDIUM="gpt-4o"
AI_MODEL_STRONG="claude-opus-4-20250514"
AI_MODEL_SEARCH="gpt-4o-mini"

# --- Perplexity (busca alternativa — opcional) ---
PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL="sonar-pro"
AI_SEARCH_PROVIDER="openai"

# --- WhatsApp (Z-API) ---
ZAPI_INSTANCE="SUA_INSTANCIA"
ZAPI_TOKEN="SEU_TOKEN"
ZAPI_CLIENT_TOKEN="SEU_CLIENT_TOKEN"

# --- Instagram / Meta (desativado — reativar quando social media voltar) ---
# META_APP_ID="SEU_APP_ID"
# META_APP_SECRET="SEU_APP_SECRET"
# META_REDIRECT_URI="https://app.exemplo.com/api/instagram/callback"
# INSTAGRAM_APP_ID="SEU_APP_ID"
# INSTAGRAM_APP_SECRET="SEU_APP_SECRET"
